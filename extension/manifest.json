{
  "manifest_version": 3,
  "name": "Intercom",
  "version": "1.0.0",
  "description": "Chat with any webpage using AI. Extension: HTML, CSS, JS. Backend: SQLite + ChromaDB + API.",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Intercom"
  }
}
